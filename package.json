{
  "name": "@rachelallyson/spectra",
  "version": "0.4.0",
  "description": "Stratum-style typed observability primitives — bring your own catalog, get typed emit, publisher fan-out, request context, test harness, and coverage report.",
  "license": "MIT",
  "author": "Rachel Allyson",
  "homepage": "https://github.com/rachelallyson/spectra#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rachelallyson/spectra.git"
  },
  "bugs": {
    "url": "https://github.com/rachelallyson/spectra/issues"
  },
  "keywords": [
    "observability",
    "telemetry",
    "events",
    "typescript",
    "zod",
    "catalog",
    "stratum",
    "logging",
    "tracing",
    "trpc",
    "inngest"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./catalog": {
      "types": "./dist/catalog.d.ts",
      "import": "./dist/catalog.js"
    },
    "./schemas": {
      "types": "./dist/schemas.d.ts",
      "import": "./dist/schemas.js"
    },
    "./metadata": {
      "types": "./dist/metadata.d.ts",
      "import": "./dist/metadata.js"
    },
    "./publishers": {
      "types": "./dist/publishers.d.ts",
      "import": "./dist/publishers.js"
    },
    "./publishers/node": {
      "types": "./dist/publishers-node.d.ts",
      "import": "./dist/publishers-node.js"
    },
    "./publisher-utils": {
      "types": "./dist/publisher-utils.d.ts",
      "import": "./dist/publisher-utils.js"
    },
    "./otel": {
      "types": "./dist/otel-publisher.d.ts",
      "import": "./dist/otel-publisher.js"
    },
    "./http-publisher": {
      "types": "./dist/http-publisher.d.ts",
      "import": "./dist/http-publisher.js"
    },
    "./context": {
      "types": "./dist/context.d.ts",
      "import": "./dist/context.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "import": "./dist/errors.js"
    },
    "./wrappers": {
      "types": "./dist/wrappers.d.ts",
      "import": "./dist/wrappers.js"
    },
    "./test-harness": {
      "types": "./dist/test-harness.d.ts",
      "import": "./dist/test-harness.js"
    },
    "./coverage": {
      "types": "./dist/coverage.d.ts",
      "import": "./dist/coverage.js"
    },
    "./coverage-report": {
      "types": "./dist/coverage-report.d.ts",
      "import": "./dist/coverage-report.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@9.15.0",
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "typecheck:examples": "tsc --noEmit -p examples/basic/tsconfig.json && tsc --noEmit -p examples/browser-react/tsconfig.json && tsc --noEmit -p examples/server-trpc-otel/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:package": "publint && attw --pack . --profile esm-only && bash ./scripts/smoke-test-tarball.sh",
    "size": "size-limit",
    "bench": "tsx bench/emit.bench.ts",
    "release": "pnpm build && pnpm test && pnpm lint:package && changeset publish",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepublishOnly": "pnpm build && pnpm test && pnpm lint:package"
  },
  "peerDependencies": {
    "@opentelemetry/api": "^1.9.0",
    "zod": "^3.24.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/api": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.31.0",
    "@opentelemetry/api": "^1.9.1",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@types/node": "^22.10.2",
    "happy-dom": "^20.9.0",
    "publint": "^0.3.18",
    "size-limit": "^12.1.0",
    "tinybench": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.2",
    "vitepress": "^1.6.4",
    "vitest": "^2.1.8",
    "zod": "^3.25.76"
  }
}
