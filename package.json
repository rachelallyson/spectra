{
  "name": "@rachelallyson/spectra",
  "version": "0.2.1",
  "description": "Stratum-style typed observability primitives — bring your own catalog, get typed emit, publisher fan-out, request context, test harness, and coverage report.",
  "license": "MIT",
  "author": "Rachel Allyson",
  "homepage": "https://github.com/rachelallyson/spectra#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rachelallyson/spectra.git"
  },
  "bugs": {
    "url": "https://github.com/rachelallyson/spectra/issues"
  },
  "keywords": [
    "observability",
    "telemetry",
    "events",
    "typescript",
    "zod",
    "catalog",
    "stratum",
    "logging",
    "tracing",
    "trpc",
    "inngest"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./catalog": {
      "types": "./dist/catalog.d.ts",
      "import": "./dist/catalog.js"
    },
    "./publishers": {
      "types": "./dist/publishers.d.ts",
      "import": "./dist/publishers.js"
    },
    "./publishers/node": {
      "types": "./dist/publishers-node.d.ts",
      "import": "./dist/publishers-node.js"
    },
    "./http-publisher": {
      "types": "./dist/http-publisher.d.ts",
      "import": "./dist/http-publisher.js"
    },
    "./context": {
      "types": "./dist/context.d.ts",
      "import": "./dist/context.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "import": "./dist/errors.js"
    },
    "./wrappers": {
      "types": "./dist/wrappers.d.ts",
      "import": "./dist/wrappers.js"
    },
    "./test-harness": {
      "types": "./dist/test-harness.d.ts",
      "import": "./dist/test-harness.js"
    },
    "./coverage": {
      "types": "./dist/coverage.d.ts",
      "import": "./dist/coverage.js"
    },
    "./coverage-report": {
      "types": "./dist/coverage-report.d.ts",
      "import": "./dist/coverage-report.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "typecheck:examples": "tsc --noEmit -p examples/basic/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepublishOnly": "pnpm build && pnpm test"
  },
  "peerDependencies": {
    "zod": "^3.24.0 || ^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2",
    "vitepress": "^1.6.4",
    "vitest": "^2.1.8",
    "zod": "^3.24.1"
  }
}
